generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/solarscout_pro/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  leads          Lead[]
  searchHistory  SearchHistory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id            String   @id @default(cuid())
  userId        String
  businessName  String?
  businessType  String?
  buildingType  String?
  address       String?
  city          String?
  country       String?
  latitude      Float
  longitude     Float
  roofAreaSqm   Float?
  contactPhone  String?
  contactEmail  String?
  website       String?
  osmId         String?
  notes         String?  @db.Text
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Google Solar API cached data
  solarDataFetchedAt       DateTime?
  solarApiStatus           String?   // "OK" | "NOT_FOUND" | "ERROR" | "NO_COVERAGE"
  solarImageryQuality      String?   // "HIGH" | "MEDIUM" | "BASE"
  solarImageryDate         String?   // e.g. "2023-06-14"
  solarMaxPanelCount       Int?
  solarMaxArrayAreaSqm     Float?
  solarMaxSunshineHours    Float?
  solarYearlyEnergyKwh     Float?
  solarCarbonOffsetKgYr    Float?
  solarPanelCapacityWatts  Float?
  solarPanelLifetimeYears  Int?
  solarRawJson             Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([country])
  @@index([city])
  @@index([businessType])
  @@index([createdAt])
  @@index([solarApiStatus])
  @@unique([userId, osmId])
}

model SearchHistory {
  id                String   @id @default(cuid())
  userId            String
  locationSearched  String
  country           String?
  leadsFound        Int      @default(0)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
