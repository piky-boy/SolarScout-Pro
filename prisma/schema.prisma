generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            String    @default("USER")
  approved        Boolean   @default(false)
  surveyCompleted Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Stripe billing
  stripeCustomerId       String?   @unique
  stripePriceId          String?
  stripeSubscriptionId   String?
  stripeCurrentPeriodEnd DateTime?
  plan                   String    @default("free") // free | pro | agency

  accounts        Account[]
  sessions        Session[]
  leads           Lead[]
  searchHistory   SearchHistory[]
  surveyResponse  SurveyResponse?
}

model SurveyResponse {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @unique @db.ObjectId
  companyName      String?
  companyRole      String?
  teamSize         String?
  marketsOfInterest String?
  monthlyLeadGoal  String?
  howDidYouHear    String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  businessName  String?
  businessType  String?
  buildingType  String?
  address       String?
  city          String?
  country       String?
  latitude      Float
  longitude     Float
  roofAreaSqm   Float?
  contactPhone  String?
  contactEmail  String?
  website       String?
  osmId         String?
  googlePlaceId String?
  dataSource    String   @default("OSM")   // "OSM" | "GOOGLE_PLACES" | "HYBRID"
  openingHours  Json?
  googleRating  Float?
  googleRatingCount Int?
  notes         String?
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Google Solar API cached data
  solarDataFetchedAt       DateTime?
  solarApiStatus           String?   // "OK" | "NOT_FOUND" | "ERROR" | "NO_COVERAGE"
  solarImageryQuality      String?   // "HIGH" | "MEDIUM" | "BASE"
  solarImageryDate         String?   // e.g. "2023-06-14"
  solarMaxPanelCount       Int?
  solarMaxArrayAreaSqm     Float?
  solarMaxSunshineHours    Float?
  solarYearlyEnergyKwh     Float?
  solarCarbonOffsetKgYr    Float?
  solarPanelCapacityWatts  Float?
  solarPanelLifetimeYears  Int?
  solarRawJson             Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([country])
  @@index([city])
  @@index([businessType])
  @@index([createdAt])
  @@index([solarApiStatus])
  @@index([dataSource])
  @@index([googlePlaceId])
  @@unique([userId, osmId])
}

model SearchHistory {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  locationSearched  String
  country           String?
  leadsFound        Int      @default(0)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
